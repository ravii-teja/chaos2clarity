  "nl_prompt": "Which customers with active CRM deals had delivery issues?",
  "gold_sql": "SELECT DISTINCT c.name FROM customers c JOIN sf_accounts sa ON c.email = sa.email_address JOIN sf_opportunities so ON sa.account_id = so.account_id JOIN orders o ON c.id = o.customer_id JOIN logistics_deliveries ld ON o.shipping_id = ld.shipping_ref WHERE so.stage NOT IN ('Closed Won', 'Closed Lost') AND ld.status_code IN (5, 6)",
