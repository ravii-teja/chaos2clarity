{
  "id": "L3-06",
  "tier": "L3",
  "nl_prompt": "Which customers have both high order value and a delayed shipment?",
  "gold_sql": "SELECT DISTINCT c.name, SUM(o.line_value) as total_rev FROM customers c JOIN orders o ON c.id = o.customer_id JOIN logistics_deliveries ld ON o.shipping_id = ld.shipping_ref WHERE ld.status_code IN (5, 6) GROUP BY c.name HAVING SUM(o.line_value) > (SELECT AVG(line_value) * 2 FROM orders)",
