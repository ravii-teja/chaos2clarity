  "nl_prompt": "What is the monthly revenue trend for the last 12 months?",
  "gold_sql": "SELECT DATE_TRUNC('month', order_date) as month, SUM(line_value) as monthly_revenue FROM orders WHERE order_date >= CURRENT_DATE - INTERVAL 365 DAY GROUP BY month ORDER BY month",
