  "nl_prompt": "Who are our top 10 customers by lifetime revenue?",
  "gold_sql": "SELECT c.name, SUM(o.line_value) as lifetime_rev FROM customers c JOIN orders o ON c.id = o.customer_id GROUP BY c.name ORDER BY lifetime_rev DESC LIMIT 10",
