  "nl_prompt": "What is the average days between order and shipment per product category?",
  "gold_sql": "SELECT p.category, AVG(o.ship_date - o.order_date) as avg_ship_days FROM orders o JOIN products p ON o.product_id = p.id WHERE o.ship_date IS NOT NULL GROUP BY p.category",
